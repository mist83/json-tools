{
  "siteId": "json-tools",
  "publishDir": "./docs",
  "dataDir": null,
  "dataPrefix": "data",
  "delete": true,
  "dataDelete": false,
  "exclude": [],
  "cacheControl": {
    "*.html": "no-store, max-age=0",
    "*.css": "no-cache, max-age=0, must-revalidate",
    "*.js": "no-cache, max-age=0, must-revalidate",
    "*.json": "no-store, max-age=0",
    "*.md": "no-store, max-age=0",
    "*.txt": "no-store, max-age=0",
    "*.webm": "public, max-age=31536000, immutable",
    "*.svg": "public, max-age=31536000, immutable"
  },
  "tags": [
    "public-frontdoor",
    "github-pages",
    "repo-artifacts"
  ],
  "notes": "Deterministic public front door for GitHub Pages plus canonical demo asset links."
}
